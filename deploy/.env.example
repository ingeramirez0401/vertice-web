# =====================================================================
# VÉRTICE · variables de entorno (.env)
# Copia a `.env` y rellena. En Portainer, cárgalas en la sección "Environment".
# =====================================================================

# Dominio público que enruta Traefik
APP_HOST=red.tudominio.com

# --- Supabase (gestionado o self-hosted) ---
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...        # clave pública (anon) — segura para el cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...            # SECRETA — solo server-side (API routes/export)

# --- Redis (definido en el compose) ---
REDIS_URL=redis://vertice-redis:6379

# --- App ---
NEXT_PUBLIC_APP_URL=https://red.tudominio.com
NEXT_PUBLIC_BRAND_NAME=VÉRTICE
NEXT_PUBLIC_REGION_LABEL=Gobernación

# --- Export (equipo de campaña) ---
# Usa un token seguro generado con: openssl rand -hex 32
EXPORT_API_KEY=cambia-esto-por-un-token-seguro
